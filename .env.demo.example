# =============================================================================
# RefuncApp — Versão Demonstrativa (Portfólio)
# =============================================================================
# Copie este arquivo para .env.local e ajuste os valores.
# Em modo demo NÃO são necessárias credenciais Supabase ou APIs externas.
# =============================================================================

# Ativa o modo demonstração (dados fictícios, sem banco real)
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# Segredo JWT — qualquer string aleatória serve em demo
JWT_SECRET=portfolio-demo-refuncapp-troque-em-producao

# Senha padrão para usuários demo (opcional — padrão: demo123)
DEFAULT_USER_PASSWORD=demo123

# =============================================================================
# NÃO NECESSÁRIAS EM DEMO_MODE:
# =============================================================================
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# MOONSHOT_API_KEY=
# MOONSHOT_MODEL=
